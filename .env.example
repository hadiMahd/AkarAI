# AkarAI Non-Secret Environment Configuration (Phase 1)
# All secrets MUST be stored in HashiCorp Vault, not in this file.
# Copy this file to .env before starting the local foundation:
#   cp .env.example .env

# Vault bootstrap (minimum to reach Vault)
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=root

# Application
APP_ENV=development
APP_DEBUG=true
PROJECT_NAME=AkarAI

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Database (PostgreSQL with pgvector)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=akarai
POSTGRES_PASSWORD=akarai
POSTGRES_DB=akarai

# Database connection URLs (through PgBouncer)
DATABASE_URL=postgresql+asyncpg://akarai:akarai@pgbouncer:6432/akarai
DATABASE_SYNC_URL=postgresql+psycopg2://akarai:akarai@pgbouncer:6432/akarai

# PgBouncer
PGBOUNCER_PORT=6432
PGBOUNCER_MAX_CLIENT_CONN=100
PGBOUNCER_DEFAULT_POOL_SIZE=20

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_SECURE=false
MINIO_PUBLIC_URL=localhost:9000
MINIO_BUCKET_RAG=rag-vault
MINIO_BUCKET_MEDIA=property-media

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001","http://localhost:8501"]

# User App
USER_APP_PORT=3000

# Agency App
AGENCY_APP_PORT=3001

# Streamlit Admin
ADMIN_PORT=8501

# ---------------------------------------------------------------------------
# Phase 2: Backend Core Foundation (non-secret placeholders only)
# Secrets (passwords, API keys) MUST be stored in HashiCorp Vault.
# Values marked TBD_ASK_USER require user selection before production use.
# ---------------------------------------------------------------------------

# Database connection URLs (PgBouncer runtime, direct for migrations)
DATABASE_URL=postgresql+asyncpg://akarai:akarai@pgbouncer:6432/akarai
PGBOUNCER_DATABASE_URL=postgresql+asyncpg://akarai:akarai@pgbouncer:6432/akarai
DATABASE_SYNC_URL=postgresql+psycopg2://akarai:akarai@pgbouncer:6432/akarai

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_PUBLIC_URL=localhost:9000

# JWT secrets — set these in your local .env; vault-init reads .env and seeds Vault.
# Leave empty to auto-generate random secrets at each docker compose up.
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=7
JWT_ALGORITHM=HS256

# AI Provider
AI_PRIMARY_PROVIDER=azure_openai
AI_FALLBACK_PROVIDERS=openrouter
AI_GUARDRAILS_ENABLED=true
AI_GUARDRAILS_USE_NEMO_RUNTIME=false
AI_GUARDRAILS_CONFIG_PATH=
AI_GUARDRAILS_MAX_HISTORY_TURNS=4
AI_GUARDRAILS_MAX_MESSAGE_CHARS=4000
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_CHAT_DEPLOYMENT=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=
# Keep for later phase
AZURE_WHISPER_DEPLOYMENT=

# OpenRouter reranking
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_RERANK_MODEL=
OPENROUTER_CONTENT_SAFETY_MODEL=

# RAG ingestion chunking
RAG_FASTCDC_MIN_SIZE=256
RAG_FASTCDC_AVG_SIZE=768
RAG_FASTCDC_MAX_SIZE=1536
RAG_FASTCDC_FAT=true
RAG_CHAT_REDIS_TTL_SECONDS=86400

# Email Provider
EMAIL_PROVIDER=resend

# ---------------------------------------------------------------------------
# Phase 11: Search (AI Text Search & Voice Search)
# ---------------------------------------------------------------------------
# SEARCH_MANUAL_RATE_LIMIT_MAX_REQUESTS=30
# SEARCH_MANUAL_RATE_LIMIT_WINDOW_SECONDS=60
# SEARCH_AI_TEXT_RATE_LIMIT_MAX_REQUESTS=10
# SEARCH_AI_TEXT_RATE_LIMIT_WINDOW_SECONDS=60
# SEARCH_VOICE_RATE_LIMIT_MAX_REQUESTS=5
# SEARCH_VOICE_RATE_LIMIT_WINDOW_SECONDS=60
# VOICE_MAX_FILE_SIZE_MB=10
# VOICE_ALLOWED_CONTENT_TYPES=audio/wav,audio/mpeg,audio/mp4,audio/webm,audio/ogg
# VOICE_REQUEST_TIMEOUT_SECONDS=30

# Hugging Face — read from .env by vault-init, seeded to Vault (akarai/ai.hf_token)
# Worker reads it from Vault at startup via configure_secrets(), NOT from env directly.
# Set a valid token for NSFW moderation; leave empty to run fail-closed (all images rejected).
HF_TOKEN=TBD_ASK_USER
